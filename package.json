{
  "name": "billard-coffe",
  "version": "1.0.0",
  "description": "Billiard Cafe Management - React SPA + Express API",
  "main": "client/vite.config.js",
  "scripts": {
    "dev": "concurrently -n SERVER,CLIENT -c \"bgBlue,bgGreen\" \"npm run dev --prefix server-api\" \"npm run dev --prefix client\"",
    "dev:server": "npm run dev --prefix server-api",
    "dev:client": "npm run dev --prefix client",
    "start": "npm run dev --prefix client",
    "build:css": "npx tailwindcss -i ./src/styles/input.css -o ./public/css/styles.css --minify",
    "watch:css": "npx tailwindcss -i ./src/styles/input.css -o ./public/css/styles.css --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^4.0.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "acorn": "^8.16.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "espree": "^11.2.0",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18"
  }
}
