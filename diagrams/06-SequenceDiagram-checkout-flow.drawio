        <mxCell id="msg8" value="8. INSERT INTO order_items&#xa;   (fee description)" style="endArrow=classic;html=1;exitX=1;exitY=0;exitDx=0;exitDy=0;entryX=0;entryY=0;entryDx=0;entryDy=0;strokeColor=#7B1FA2;strokeWidth=2;dashed=1;fontSize=9;fontColor=#7B1FA2;" edge="1" parent="1">
