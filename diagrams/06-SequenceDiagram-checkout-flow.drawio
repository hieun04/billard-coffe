            <mxPoint x="310" y="200" as="sourcePoint"/>
            <mxPoint x="435" y="200" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 4. Get table info -->
        <mxCell id="msg4" value="4. SELECT * FROM tables WHERE id=?" style="endArrow=classic;html=1;exitX=1;exitY=0;exitDx=0;exitDy=0;entryX=0;entryY=0;entryDx=0;entryDy=0;strokeColor=#7B1FA2;strokeWidth=2;dashed=1;fontSize=9;fontColor=#7B1FA2;" edge="1" parent="1">
