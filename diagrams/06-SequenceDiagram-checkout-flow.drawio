        <mxCell id="msg3" value="3. checkout(req, res)" style="endArrow=classic;html=1;exitX=1;exitY=0;exitDx=0;exitDy=0;entryX=0;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;strokeWidth=2;fontSize=10;" edge="1" parent="1">
