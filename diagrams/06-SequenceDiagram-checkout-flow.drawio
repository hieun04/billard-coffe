            <mxPoint x="65" y="160" as="sourcePoint"/>
            <mxPoint x="145" y="160" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 2. Browser sends request -->
        <mxCell id="msg2" value="2. HTTP POST /tables/:id/checkout" style="endArrow=classic;html=1;exitX=1;exitY=0;exitDx=0;exitDy=0;entryX=0;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;strokeWidth=2;fontSize=10;" edge="1" parent="1">
