          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="240" as="sourcePoint"/>
            <mxPoint x="455" y="240" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 6. Calculate duration & totals -->
        <mxCell id="msg6" value="6. Calculate:&#xa;   hours = diff(start, now)&#xa;   billiardTotal = hours * rate&#xa;   grandTotal = drinks + billiard" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=9;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="470" y="260" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- 7. Update order -->
        <mxCell id="msg7" value="7. UPDATE orders&#xa;   SET subtotal=?, total=?,&#xa;   status='paid'" style="endArrow=classic;html=1;exitX=1;exitY=0;exitDx=0;exitDy=0;entryX=0;entryY=0;entryDx=0;entryDy=0;strokeColor=#7B1FA2;strokeWidth=2;dashed=1;fontSize=9;fontColor=#7B1FA2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="450" y="320" as="sourcePoint"/>
            <mxPoint x="560" y="320" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

