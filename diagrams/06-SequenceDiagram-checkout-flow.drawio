        <!-- MESSAGES -->
        <!-- 1. Staff clicks "Checkout" -->
        <mxCell id="msg1" value="1. POST /tables/:id/checkout" style="endArrow=classic;html=1;exitX=1;exitY=0;exitDx=0;exitDy=0;entryX=0;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;strokeWidth=2;fontSize=10;" edge="1" parent="1">
